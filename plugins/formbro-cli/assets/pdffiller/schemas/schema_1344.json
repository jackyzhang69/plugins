        },
        "Other": { "type": "string" },
        "ConjugalFromDate": { "type": "string", "format": "date" }
      },
      "required": ["Proceed", "Language", "Co-signer", "FamilyName", "Dob", "Relationship"],
      "allOf": [
        {
          "if": {
            "properties": {
              "Relationship": { "const": "Conjugal partner outside Canada" }
            }
          },
          "then": {
            "required": ["ConjugalFromDate"]
          }
        },
