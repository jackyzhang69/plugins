          "bin/darwin-arm64/pdf-fill-xfa",
          "bin/darwin-arm64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-darwin-arm64.tar.gz",
            "archive": "tar.gz",
            "sha256": "b93c47d406fc976f609556dcc82a02e0afcbfd619c5cbdd6065ec6a3a274a109"
          },
