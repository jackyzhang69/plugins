          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-linux-x64.tar.gz",
            "archive": "tar.gz",
            "sha256": "549d06acfe270cd461c98cc58ee47e5312f59133edacd16df049ce1b7715c6ff"
          },
          {
            "name": "webform-worker",
