{
  "$schema": "https://formbro.ca/schemas/runtime-manifest-v3.json",
  "version": 3,
  "binary": {
    "name": "formbro",
    "platforms": {
      "darwin-arm64": {
        "entrypoint": "bin/darwin-arm64/formbro",
        "siblings": [
          "bin/darwin-arm64/pdf-fill-xfa",
          "bin/darwin-arm64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-darwin-arm64.tar.gz",
            "archive": "tar.gz",
            "sha256": "3fcc730ad4f0386d981a0dbf8edf72c4d80e298562f3fcfe8bbead2d4accae36"
          },
          {
            "name": "webform-worker",
            "asset": "webform-worker-darwin-arm64.tar.gz",
            "archive": "tar.gz",
            "sha256": "fcebe12da11833dfbdcaefabc1c435bfc0c2623f6978c3cf65ed3373934fbbb3"
          }
        ]
      },
      "darwin-x64": {
        "entrypoint": "bin/darwin-x64/formbro",
        "siblings": [
          "bin/darwin-x64/pdf-fill-xfa",
          "bin/darwin-x64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-darwin-x64.tar.gz",
