{
  "$schema": "https://formbro.ca/schemas/runtime-manifest-v3.json",
  "version": 3,
  "binary": {
    "name": "formbro",
    "platforms": {
      "darwin-arm64": {
        "entrypoint": "bin/darwin-arm64/formbro",
        "siblings": [
          "bin/darwin-arm64/pdf-fill-xfa",
          "bin/darwin-arm64/extract-orig-oid"
        ],
        "lazy": {
          "name": "formbro-pdfjs",
          "asset": "formbro-pdfjs-darwin-arm64.tar.gz",
          "archive": "tar.gz",
          "sha256": "646a471c0202ee1272d5c953a3f2d7d6b215bc99b6cc27a84fd31f9f3610076e"
        }
      },
      "darwin-x64": {
        "entrypoint": "bin/darwin-x64/formbro",
        "siblings": [
          "bin/darwin-x64/pdf-fill-xfa",
          "bin/darwin-x64/extract-orig-oid"
        ],
        "lazy": {
          "name": "formbro-pdfjs",
          "asset": "formbro-pdfjs-darwin-x64.tar.gz",
          "archive": "tar.gz",
          "sha256": "44ba306c1744ee8d0e1c2fbde1390628e538440ff8681eea06868a15ffec711b"
        }
      },
      "win32-x64": {
        "entrypoint": "bin/win32-x64/formbro.exe",
        "siblings": [
          "bin/win32-x64/pdf-fill-xfa.exe",
          "bin/win32-x64/extract-orig-oid.exe"
        ],
        "lazy": {
          "name": "formbro-pdfjs.exe",
          "asset": "formbro-pdfjs-win32-x64.zip",
          "archive": "zip",
          "sha256": "2cd3150127bd5d668ee3fbb8554a18b3391ea88429d8be3f83f538c4b3d18d09"
        }
      },
      "linux-x64": {
        "entrypoint": "bin/linux-x64/formbro",
        "siblings": [
          "bin/linux-x64/pdf-fill-xfa",
          "bin/linux-x64/extract-orig-oid"
        ],
        "lazy": {
          "name": "formbro-pdfjs",
          "asset": "formbro-pdfjs-linux-x64.tar.gz",
          "archive": "tar.gz",
          "sha256": "a1b26a6cb8fb721ea9ecca0834fb9ebb31a244fc7e7e4d0cdeecfae335f3add7"
        }
      },
      "linux-arm64": {
        "entrypoint": "bin/linux-arm64/formbro",
        "siblings": [
          "bin/linux-arm64/pdf-fill-xfa",
          "bin/linux-arm64/extract-orig-oid"
        ],
        "lazy": {
          "name": "formbro-pdfjs",
          "asset": "formbro-pdfjs-linux-arm64.tar.gz",
          "archive": "tar.gz",
          "sha256": "ac70c757b652700e625a7f271d7eb6bbbb7618b02f065862b0bfd82217f2f554"
        }
      }
    },
    "release": {
      "host": "github-releases",
      "repo": "jackyzhang69/plugins",
      "tag": "main-b9cea999c13ac59d5551645a45163d656c293d96"
    },
    "resolutionOrder": [
      "${platform}-${arch}"
    ],
    "fallbackBehavior": "fail",
    "verifyChecksum": true
  },
  "cacheDir": {
    "darwin": "${HOME}/.cache/formbro-cli",
    "linux": "${HOME}/.cache/formbro-cli",
    "win32": "${LOCALAPPDATA}/formbro-cli/Cache"
  },
  "configHome": {
    "darwin": "${HOME}/.formbro",
    "linux": "${HOME}/.formbro",
    "win32": "${USERPROFILE}/.formbro"
  },
  "configFile": "config.json",
  "tokenEnvVar": "FORMBRO_API_TOKEN",
  "defaultBaseUrl": "https://backend.formbro.ca"
}
