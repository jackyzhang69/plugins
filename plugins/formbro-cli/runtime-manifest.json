          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-linux-x64.tar.gz",
            "archive": "tar.gz",
            "sha256": "57efa409feb86d781dd9f8089dea77756d7dab9c7bfa79b688da940758c4bf7f"
          },
          {
            "name": "webform-worker",
            "asset": "webform-worker-linux-x64.tar.gz",
