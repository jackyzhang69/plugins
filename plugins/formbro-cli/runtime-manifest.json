          "bin/darwin-arm64/pdf-fill-xfa",
          "bin/darwin-arm64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-darwin-arm64.tar.gz",
            "archive": "tar.gz",
            "sha256": "9bf32cc97a4e2b261ff75e0a28ca02cbd220baa4e154ba3bfb3d7c2c65de4033"
          },
          {
