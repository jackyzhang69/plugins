        "entrypoint": "bin/linux-x64/formbro",
        "siblings": [
          "bin/linux-x64/pdf-fill-xfa",
          "bin/linux-x64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-linux-x64.tar.gz",
            "archive": "tar.gz",
            "sha256": "c2866378a8aa87c86cb1b283e220117d185c13506fdcc85f61254e661aee07ec"
          },
          {
            "name": "webform-worker",
            "asset": "webform-worker-linux-x64.tar.gz",
