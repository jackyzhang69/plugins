            "sha256": "95e6323e798434803d16aef0284e46b662b68bc429eeb7f626ca40fbd467eb86"
          }
        ]
      },
      "linux-arm64": {
        "entrypoint": "bin/linux-arm64/formbro",
        "siblings": [
          "bin/linux-arm64/pdf-fill-xfa",
          "bin/linux-arm64/extract-orig-oid"
        ],
        "lazy": [
          {
            "name": "formbro-pdfjs",
            "asset": "formbro-pdfjs-linux-arm64.tar.gz",
            "archive": "tar.gz",
            "sha256": "9a78f6918ed9e1c7ff5ae0b46b5944d7517513b2b850590068c9b9da440ec429"
